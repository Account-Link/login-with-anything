{
  "manifest_version": 3,
  "name": "Log in with Shave and a Haircut",
  "version": "0.1.0",
  "description": "Authenticate by tapping a rhythm on a tweet",
  "permissions": ["cookies", "storage", "activeTab", "scripting"],
  "content_scripts": [{
    "matches": ["https://x.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
