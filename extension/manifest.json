{
  "manifest_version": 3,
  "name": "Login with Everything",
  "version": "0.1.0",
  "description": "Prove you're logged into any site via TEE or GitHub Actions",
  "permissions": ["cookies", "storage", "activeTab", "scripting", "tabs"],
  "optional_host_permissions": ["<all_urls>"],
  "background": { "service_worker": "service-worker.js" },
  "icons": { "16": "icon16.png", "32": "icon32.png", "48": "icon48.png", "128": "icon128.png" },
  "action": { "default_popup": "popup.html" },
  "content_scripts": [{
    "matches": ["*://*.dstack-pha-prod7.phala.network/*", "*://*.dstack-pha-prod9.phala.network/*", "http://localhost:3003/*"],
    "js": ["content-forum.js"],
    "run_at": "document_idle"
  }],
  "web_accessible_resources": [
    { "resources": ["status.html"], "matches": ["<all_urls>"] }
  ]
}
